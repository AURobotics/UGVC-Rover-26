\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% --- Intelligent Frame Selection ---
\newif\ifshowpagination
\showpaginationtrue

\let\origpagenumbering\pagenumbering

\renewcommand{\pagenumbering}[1]{%
  \origpagenumbering{#1}
  \def\temparg{#1}%
  \def\gobblearg{gobble}%
  \ifx\temparg\gobblearg
    \showpaginationfalse
  \else
    \showpaginationtrue
  \fi
}

\AddToShipoutPictureBG{%
    \AtPageLowerLeft{\includegraphics[width=\paperwidth,height=\paperheight]{assets/frame.pdf}}
    \ifshowpagination
        \AtPageLowerLeft{\includegraphics[width=\paperwidth,height=\paperheight]{assets/pagination_frame.pdf}}
        \put(562,17){%
            \makebox[10pt][c]{\textcolor{aur_color}{\large{\textbf{\thepage}}}} 
        }
    \fi
}

% --- Pulling Headings Up Closer to the Preceding Paragraphs ---
% The negative 2nd argument explicitly counters the leftover paragraph spacing
\titleformat{\section}{\color{aur_color}\normalfont\LARGE\bfseries}{\thesection\quad}{0em}{}[\titlerule]
\titlespacing*{\section}{0pt}{-4pt plus 1pt minus 1pt}{4pt plus 1pt} 

\titleformat{\subsection}{\color{aur_color}\normalfont\Large\bfseries}{\thesubsection\quad}{0em}{}
\titlespacing*{\subsection}{0pt}{-3pt plus 1pt minus 1pt}{3pt plus 1pt}

\titleformat{\subsubsection}{\normalfont\large\bfseries}{\thesubsubsection\quad}{0em}{}
\titlespacing*{\subsubsection}{0pt}{-2pt plus 1pt minus 1pt}{2pt plus 1pt}

% Hyperlink Setup
\hypersetup{
    colorlinks=true,
    linkcolor=link_color,
    filecolor=link_color,   
    urlcolor=link_color,
    pdftitle={AU-Robotics Technical Documentation},
}

% Document Start Configurations
\AtBeginDocument{
    \addtocontents{plain}{\protect\thispagestyle{plain}}
    
    % Compact, predictable spacing between standard text paragraphs
    \setlength{\parskip}{2pt plus 0.5pt minus 0.5pt} 
    \setlength{\parsep}{0pt}
}

% --- Ultra-Tight Paragraph Title Command ---
\makeatletter
\renewcommand{\paragraph}{\@startsection{paragraph}{4}{0ex}%
    {-0.5ex plus -0.1ex minus -0.1ex}%  % Reduced top spacing
    {0.2ex}%                             % Small gap before text continues
    {\normalfont\normalsize\bfseries}}
\makeatother

